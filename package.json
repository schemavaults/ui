{
  "name": "@schemavaults/ui",
  "version": "0.88.1",
  "private": false,
  "license": "MIT",
  "description": "React.js UI components for SchemaVaults frontend applications",
  "repository": {
    "type": "git",
    "url": "https://github.com/schemavaults/ui.git"
  },
  "peerDependencies": {
    "react": "19.2.8",
    "react-dom": "19.2.8"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "1.4.0",
    "@hookform/resolvers": "3.9.0",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "1.3.2",
    "@radix-ui/react-context-menu": "2.2.15",
    "@radix-ui/react-dialog": "1.1.14",
    "@radix-ui/react-dropdown-menu": "2.1.15",
    "@radix-ui/react-hover-card": "1.1.14",
    "@radix-ui/react-label": "2.1.7",
    "@radix-ui/react-navigation-menu": "1.2.13",
    "@radix-ui/react-popover": "1.1.14",
    "@radix-ui/react-radio-group": "1.3.7",
    "@radix-ui/react-scroll-area": "1.2.9",
    "@radix-ui/react-select": "2.2.5",
    "@radix-ui/react-separator": "1.1.7",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.14",
    "@radix-ui/react-tooltip": "1.2.7",
    "@radix-ui/react-visually-hidden": "1.2.3",
    "@schemavaults/theme": "0.26.1",
    "@tanstack/react-table": "8.20.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "framer-motion": "12.23.24",
    "lucide-react": "0.575.0",
    "next-themes": "0.4.6",
    "react-hook-form": "7.76.1",
    "tailwind-merge": "3.0.2"
  },
  "devDependencies": {
    "@schemavaults/send-email": "0.1.0",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/addon-webpack5-compiler-swc": "4.0.3",
    "@storybook/react": "10.5.3",
    "@storybook/react-webpack5": "10.5.3",
    "@storybook/test-runner": "0.24.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "autoprefixer": "10.4.21",
    "base64url": "3.0.1",
    "buffer": "6.0.3",
    "bun-types": "1.3.14",
    "concurrently": "10.0.3",
    "eslint": "9.39.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.5.3",
    "globals": "16.5.0",
    "http-server": "14.1.1",
    "ignore-loader": "0.1.2",
    "postcss": "8.5.12",
    "postcss-loader": "8.1.1",
    "semver": "7.7.2",
    "storybook": "10.5.3",
    "tailwindcss": "3.4.17",
    "tsc-alias": "1.8.16",
    "typescript": "5.9.3",
    "wait-on": "9.0.10",
    "webpack": "5.102.0"
  },
  "scripts": {
    "build:pkg": "tsc --project tsconfig.pkg.json && tsc-alias --project tsconfig.pkg.json",
    "build:storybook": "storybook build",
    "build": "bun run build:pkg",
    "prebuild": "bun run clean",
    "clean": "rm -rf ./dist",
    "storybook": "storybook dev -p 6006",
    "preview": "bun run storybook",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --project tsconfig.pkg.json --noEmit",
    "typecheck:storybook": "tsc --project tsconfig.json --noEmit",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook\""
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*",
      "require": "./dist/*"
    },
    "./dist": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./dist/*": {
      "types": "./dist/*",
      "import": "./dist/*",
      "require": "./dist/*"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*",
      "import": "./dist/providers/*",
      "require": "./dist/providers/*"
    },
    "./framer-motion": {
      "types": "./dist/framer-motion.d.ts",
      "import": "./dist/framer-motion.js",
      "require": "./dist/framer-motion.js"
    }
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.14",
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
